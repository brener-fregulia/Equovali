# Copie este arquivo para .env e preencha com valores reais.
# O .env NUNCA é commitado — é enviado manualmente via FTP para
# fora da pasta public_html (ex: /home/equovali1/.env).

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=Equovali

# E-mail que recebe as inscrições da lista de espera
MAIL_TO_EMAIL=

# Opcional: e-mail que recebe cópia oculta (BCC) de cada inscrição.
# Deixe em branco se não for necessário.
MAIL_BCC_EMAIL=
